{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile picture URL" },
        "theme": {
          "type": "object",
          "properties": {
            "bg": { "type": "string" },
            "accent": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the message" },
        "role": { "type": "string", "enum": ["user", "ai"] },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "isError": { "type": "boolean" },
        "mode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text", "createdAt"]
    },
    "Thread": {
      "title": "Thread",
      "description": "A chat conversation thread",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/threads": {
      "schema": "Thread",
      "description": "User's chat threads"
    },
    "users/{userId}/threads/{threadId}/messages": {
      "schema": "Chat",
      "description": "Messages within a specific thread"
    }
  }
}
